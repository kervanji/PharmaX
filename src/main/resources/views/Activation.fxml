<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane stylesheets="@../styles/main.css" styleClass="login-pane"
            style="-fx-font-family: 'Geeza Pro', 'SF Arabic', 'Arial', 'Tahoma';"
            xmlns:fx="http://javafx.com/fxml" fx:controller="com.pharmax.controller.ActivationController"
            prefWidth="520" prefHeight="650">

    <center>
        <VBox alignment="CENTER">
            <VBox alignment="CENTER" spacing="12"
                  style="-fx-background-color: -fx-btn-secondary-bg; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10);"
                  maxWidth="450">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>

                <Label text="PharmaX" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: -fx-accent-color;">
                    <font><Font name="System Bold" size="30"/></font>
                </Label>

                <Label text="انتهت الفترة التجريبية" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-danger-text;"/>
                <Label text="يرجى التواصل مع المطور للحصول على كود تفعيل دائم." style="-fx-font-size: 13px; -fx-text-fill: -fx-text-hint;" textAlignment="CENTER" wrapText="true"/>

                <VBox spacing="4" alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 10; -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8;">
                    <Label text="معلومات المطور" style="-fx-text-fill: -fx-text-main; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Label text="المطور: KervanjiHolding" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;"/>
                    <Label text="البرنامج: PharmaX" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;"/>
                    <Label text="واتساب/هاتف: 07730199732" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;"/>
                    <Label text="الموقع الإلكتروني: kervanjiholding.com" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;"/>
                </VBox>

                <VBox spacing="8" alignment="CENTER">
                    <Label text="كود الجهاز" style="-fx-text-fill: -fx-text-main; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER">
                        <Label fx:id="deviceIdLabel" text="" style="-fx-text-fill: -fx-accent-hover; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: rgba(0,0,0,0.2); -fx-padding: 8 12; -fx-background-radius: 5;"/>
                        <Button text="نسخ" onAction="#handleCopyDeviceCode"
                                style="-fx-background-color: -fx-accent-color; -fx-text-fill: white; -fx-font-size: 12px; -fx-cursor: hand; -fx-background-radius: 5;"/>
                    </HBox>
                </VBox>

                <VBox spacing="8" alignment="CENTER">
                    <Label text="أدخل كود التفعيل" style="-fx-text-fill: -fx-text-main; -fx-font-size: 14px;"/>
                    <TextField fx:id="activationCodeField" promptText="HX1-XXXXXX-XXXXXXXX"
                               prefWidth="320" prefHeight="40"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: -fx-border-main; -fx-border-width: 1; -fx-font-size: 14px; -fx-padding: 8;"
                               alignment="CENTER"/>
                </VBox>

                <Label fx:id="errorLabel" text="" visible="false" managed="false"
                       style="-fx-text-fill: -fx-danger-text; -fx-font-size: 13px; -fx-background-color: #fef2f2; -fx-padding: 8 15; -fx-background-radius: 8;"/>

                <Label fx:id="statusLabel" text="" style="-fx-text-fill: -fx-success-dark; -fx-font-size: 13px;"/>

                <Button fx:id="activateButton" text="تفعيل" onAction="#handleActivate"
                        prefWidth="320" prefHeight="45"
                        style="-fx-background-color: -fx-accent-color; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>

                <Button text="خروج" onAction="#handleExit"
                        style="-fx-background-color: transparent; -fx-text-fill: -fx-text-muted; -fx-font-size: 12px; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <VBox alignment="CENTER">
            <padding>
                <Insets bottom="20"/>
            </padding>
            <Label text="© 2026 KervanjiHolding" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 11px;"/>
        </VBox>
    </bottom>
</BorderPane>
