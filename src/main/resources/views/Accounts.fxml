<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmax.controller.AccountsController"
      stylesheets="@../styles/main.css"
      style="-fx-padding: 15;">

    <!-- ===== Toolbar ===== -->
    <HBox spacing="8" alignment="CENTER_LEFT"
          style="-fx-background-color: -fx-bg-tertiary; -fx-padding: 10; -fx-background-radius: 10;">
        <Label text="� حسابات" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -fx-form-label;"/>
        <Separator orientation="VERTICAL"/>
        <ComboBox fx:id="customerCombo" prefWidth="200" promptText="اختر العميل"/>
        <ComboBox fx:id="projectCombo" prefWidth="120" promptText="المشروع"/>
        <ComboBox fx:id="currencyCombo" prefWidth="80"/>
        <DatePicker fx:id="fromDate" prefWidth="110" promptText="من"/>
        <DatePicker fx:id="toDate" prefWidth="110" promptText="إلى"/>
        <Button fx:id="generateBtn" text="عرض" styleClass="button-primary"/>
        <Button fx:id="printBtn" text="طباعة PDF" styleClass="button-success"/>
        <CheckBox fx:id="showDetailsCheck" text="تفاصيل المواد"
                  style="-fx-text-fill: -fx-form-label; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 0 5 0 0;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="👁" onAction="#handleViewSelectedCustomer" style="-fx-background-color: -fx-accent-color; -fx-text-fill: white; -fx-padding: 6 10; -fx-background-radius: 6; -fx-cursor: hand;"/>
        <Button text="✏️" onAction="#handleEditSelectedCustomer" style="-fx-background-color: -fx-accent-light; -fx-text-fill: white; -fx-padding: 6 10; -fx-background-radius: 6; -fx-cursor: hand;"/>
        <Button text="🗑" onAction="#handleDeleteSelectedCustomer" style="-fx-background-color: -fx-danger; -fx-text-fill: white; -fx-padding: 6 10; -fx-background-radius: 6; -fx-cursor: hand;"/>
        <Button text="+ عميل" onAction="#handleAddCustomer"
                style="-fx-background-color: linear-gradient(to right, #10b981, #059669); -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 6 12; -fx-background-radius: 6;"/>
    </HBox>

    <TableView fx:id="statementTable" VBox.vgrow="ALWAYS" nodeOrientation="RIGHT_TO_LEFT">
        <columns>
            <TableColumn fx:id="colDate" text="التاريخ" prefWidth="120" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colType" text="النوع" prefWidth="90" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colRef" text="رقم المرجع" prefWidth="90" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colDesc" text="البيان" prefWidth="180" style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="colDebit" text="مدين (لنا)" prefWidth="100" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colCredit" text="دائن (دفعة)" prefWidth="100" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colBalance" text="الرصيد" prefWidth="110" style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
            <TableColumn fx:id="colPayStatus" text="حالة الدفع" prefWidth="70" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colActions" text="الإجراءات" prefWidth="130" style="-fx-alignment: CENTER;"/>
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        <placeholder><Label text="اختر العميل ثم اضغط عرض"/></placeholder>
    </TableView>

    <HBox spacing="25" alignment="CENTER"
          style="-fx-background-color: -fx-bg-tertiary; -fx-background-radius: 8; -fx-padding: 8;">
        <VBox alignment="CENTER" spacing="2">
            <Label text="إجمالي مدين" style="-fx-font-size: 10px; -fx-text-fill: -fx-form-sublabel;"/>
            <Label fx:id="totalDebitLabel" text="0.00" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -fx-danger-text;"/>
        </VBox>
        <Separator orientation="VERTICAL"/>
        <VBox alignment="CENTER" spacing="2">
            <Label text="اجمالي المدفوع" style="-fx-font-size: 10px; -fx-text-fill: -fx-form-sublabel;"/>
            <Label fx:id="totalCreditLabel" text="0.00" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #22c55e;"/>
        </VBox>
        <Separator orientation="VERTICAL"/>
        <VBox alignment="CENTER" spacing="2">
            <Label text="الرصيد النهائي" style="-fx-font-size: 10px; -fx-text-fill: -fx-form-sublabel;"/>
            <Label fx:id="finalBalanceLabel" text="0.00" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -fx-form-label;"/>
        </VBox>
        <Separator orientation="VERTICAL"/>
        <VBox alignment="CENTER" spacing="2">
            <Label text="عدد الحركات" style="-fx-font-size: 10px; -fx-text-fill: -fx-form-sublabel;"/>
            <Label fx:id="totalCountLabel" text="0" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -fx-form-label;"/>
        </VBox>
        <Separator orientation="VERTICAL"/>
        <VBox alignment="CENTER" spacing="2">
            <Label text="معلق" style="-fx-font-size: 10px; -fx-text-fill: -fx-form-sublabel;"/>
            <Label fx:id="pendingTotalLabel" text="0.00" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -fx-danger-text;"/>
        </VBox>
        <Separator orientation="VERTICAL"/>
        <VBox alignment="CENTER" spacing="2">
            <Label text="فواتير معلقة" style="-fx-font-size: 10px; -fx-text-fill: -fx-form-sublabel;"/>
            <Label fx:id="pendingCountLabel" text="0" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -fx-warning-text;"/>
        </VBox>
    </HBox>


</VBox>
