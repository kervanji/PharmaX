<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pharmax.controller.PurchaseController"
            fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: transparent; -fx-background: transparent;">

    <VBox fx:id="rootContainer"
          stylesheets="@../styles/main.css"
          spacing="15"
          style="-fx-background-color: -fx-bg-gradient; -fx-padding: 20; -fx-font-family: 'Geeza Pro', 'SF Arabic', 'Arial', 'Tahoma';">
    
    <!-- Header -->
    <HBox fx:id="pageHeader" alignment="CENTER" spacing="20" style="-fx-background-color: linear-gradient(to left, -fx-warning, -fx-warning-dark); -fx-padding: 15; -fx-background-radius: 12;">
        <Label text="المشتريات" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="previousPurchasesBtn" text="المشتريات السابقة" onAction="#showPreviousPurchases"
                style="-fx-background-color: -fx-btn-secondary-bg; -fx-text-fill: -fx-warning-dark; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8;"/>
    </HBox>
    
    <HBox fx:id="mainContentBox" spacing="20" VBox.vgrow="ALWAYS">
        <!-- Left Panel - Supplier Balance Info -->
        <VBox fx:id="balancePanel" spacing="10" VBox.vgrow="ALWAYS" style="-fx-background-color: -fx-badge-warning-bg; -fx-padding: 15; -fx-background-radius: 12; -fx-min-width: 220;">
            <Label text="الرصيد السابق" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -fx-form-label;"/>
            <Label fx:id="previousBalanceLabel" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-badge-warning-text;"/>
            
            <Separator/>
            
            <Label text="الرصيد الحالي" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -fx-form-label;"/>
            <Label fx:id="currentBalanceLabel" text="0 د.ع" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-badge-warning-text;"/>
            
            <Separator/>
            
            <Label text="إجمالي المواد" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -fx-form-label;"/>
            <Label fx:id="itemsTotalLabel" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-badge-success-text;"/>
            
            <Separator/>
            
            <Label text="الصافي (بعد الخصم)" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -fx-form-label;"/>
            <Label fx:id="totalAmountLabel" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-danger-text;"/>
        </VBox>
        
        <!-- Right Panel - Form -->
        <VBox fx:id="formPanel" spacing="15" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" style="-fx-background-color: -fx-form-section-bg; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 14, 0, 0, 6);">

            <GridPane fx:id="formGrid" hgap="6" vgap="10" nodeOrientation="RIGHT_TO_LEFT" alignment="TOP_LEFT">
                <columnConstraints>
                    <ColumnConstraints percentWidth="12" halignment="LEFT"/>
                    <ColumnConstraints percentWidth="38" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="12" halignment="LEFT"/>
                    <ColumnConstraints percentWidth="38" hgrow="ALWAYS"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints valignment="CENTER" minHeight="45"/>
                    <RowConstraints valignment="CENTER" minHeight="45"/>
                    <RowConstraints valignment="CENTER" minHeight="45"/>
                    <RowConstraints valignment="CENTER" minHeight="45"/>
                </rowConstraints>

                <!-- Row 0: supplier and voucher number -->
                <Label text="اسم المذخر" style="-fx-font-weight: bold; -fx-text-fill: -fx-form-label;" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>
                <HBox spacing="8" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.valignment="CENTER" GridPane.hgrow="ALWAYS">
                    <Button text="+" onAction="#addNewCustomer" styleClass="button-danger"/>
                    <ComboBox fx:id="customerCombo" prefWidth="240" maxWidth="Infinity" promptText="اختر اسم المذخر" editable="true" HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label text="رقم المستند" style="-fx-font-weight: bold; -fx-text-fill: -fx-form-label;" GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>
                <TextField fx:id="voucherNumberField" editable="false" prefWidth="160"
                           style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-prompt-text-fill: -fx-text-hint; -fx-padding: 10; -fx-background-radius: 8;"
                           GridPane.columnIndex="3" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>

                <!-- Row 1: date -->
                <Label text="التاريخ" style="-fx-font-weight: bold; -fx-text-fill: -fx-form-label;" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                <DatePicker fx:id="voucherDatePicker" prefWidth="180" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>

                <Label text="رقم قائمة المذخر" style="-fx-font-weight: bold; -fx-text-fill: -fx-form-label;" GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                <TextField fx:id="supplierInvoiceNumberField" promptText="اختياري"
                           style="-fx-padding: 10; -fx-background-radius: 8;"
                           GridPane.columnIndex="3" GridPane.rowIndex="1" GridPane.valignment="CENTER" GridPane.hgrow="ALWAYS" maxWidth="Infinity"/>

                <!-- Row 2: Description and discount -->
                <Label text="البيان" style="-fx-font-weight: bold; -fx-text-fill: -fx-form-label;" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
                <TextField fx:id="descriptionField" promptText="مشتريات من مذخر .."
                           style="-fx-padding: 10; -fx-background-radius: 8;"
                           GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.valignment="CENTER" GridPane.hgrow="ALWAYS" maxWidth="Infinity"/>

                <Label text="الخصم" style="-fx-font-weight: bold; -fx-text-fill: -fx-form-label;" GridPane.columnIndex="2" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
                <HBox spacing="6" alignment="CENTER_LEFT" GridPane.columnIndex="3" GridPane.rowIndex="2" GridPane.valignment="CENTER" GridPane.hgrow="ALWAYS">
                    <TextField fx:id="discountPercentField" text="0" prefWidth="45"
                               style="-fx-padding: 10; -fx-background-radius: 8;"/>
                    <Label text="\%"/>
                    <TextField fx:id="discountAmountField" text="0" prefWidth="110"
                               style="-fx-padding: 10; -fx-background-radius: 8;"/>
                </HBox>

                <!-- Row 3: Notes -->
                <Label text="ملاحظات" style="-fx-font-weight: bold; -fx-text-fill: -fx-form-label;" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.valignment="CENTER"/>
                <TextArea fx:id="notesArea" prefRowCount="1" promptText="ملاحظات"
                          style="-fx-padding: 8; -fx-background-radius: 8;"
                          GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.columnSpan="3" GridPane.valignment="CENTER" GridPane.hgrow="ALWAYS" maxWidth="Infinity"/>
            </GridPane>

            <!-- Items Table Section -->
            <VBox fx:id="itemsSection" spacing="8" VBox.vgrow="ALWAYS" style="-fx-background-color: -fx-bg-main; -fx-padding: 10; -fx-background-radius: 8;">
                <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 5;">
                    <Label text="المواد المشتراة" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -fx-badge-warning-text;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="toggleTableSizeBtn" text="تكبير الجدول" onAction="#handleToggleItemsTableSize"
                            style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 8; -fx-border-color: -fx-border-input; -fx-border-radius: 8; -fx-cursor: hand;"/>
                    <Button text="+ إضافة مادة" onAction="#handleAddItem"
                            style="-fx-background-color: -fx-warning; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
                
                <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8;" editable="true">
                    <columns>
                        <TableColumn fx:id="itemProductColumn" text="المادة" prefWidth="200"/>
                        <TableColumn fx:id="itemQuantityColumn" text="الكمية" prefWidth="80"/>
                        <TableColumn fx:id="itemUnitColumn" text="الوحدة" prefWidth="80"/>
                        <TableColumn fx:id="itemBatchColumn" text="رقم التشغيلة" prefWidth="120"/>
                        <TableColumn fx:id="itemExpiryColumn" text="الصلاحية" prefWidth="110"/>
                        <TableColumn fx:id="itemPriceColumn" text="سعر الشراء" prefWidth="120"/>
                        <TableColumn fx:id="itemSalePriceColumn" text="سعر البيع" prefWidth="120"/>
                        <TableColumn fx:id="itemTotalColumn" text="المجموع" prefWidth="120"/>
                        <TableColumn fx:id="itemEditColumn" text="تعديل" prefWidth="60"/>
                        <TableColumn fx:id="itemDeleteColumn" text="حذف" prefWidth="60"/>
                    </columns>
                </TableView>
                
        </VBox>
        </VBox>
    </HBox>
    
    <!-- Action Buttons -->
    <HBox fx:id="actionButtonsBox" alignment="CENTER" spacing="15" style="-fx-padding: 10;">
        <CheckBox fx:id="printCheckbox" text="طباعة"/>
        <Button fx:id="saveBtn" text="حفظ" onAction="#handleSave"
                style="-fx-background-color: linear-gradient(to right, -fx-warning, -fx-warning-dark); -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 40; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button fx:id="newBtn" text="جديد" onAction="#handleNew"
                style="-fx-background-color: -fx-accent-light; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 40; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="إغلاق" onAction="#handleClose"
                style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 30; -fx-background-radius: 8; -fx-cursor: hand; -fx-border-color: -fx-border-input; -fx-border-radius: 8;"/>
    </HBox>
    
</VBox>
</ScrollPane>
