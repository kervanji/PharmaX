<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmax.controller.InventoryListController"
      stylesheets="@../styles/main.css"
      spacing="16"
      style="-fx-background-color: -fx-bg-gradient; -fx-padding: 24;">
    
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="إدارة المخزون" 
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -fx-form-label;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ إضافة منتج" onAction="#handleAddProduct"
                style="-fx-background-color: linear-gradient(to right, -fx-accent-light, -fx-accent-color); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 10;"/>
        <Button text="إدارة الفئات" onAction="#handleManageCategories"
                style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-border-color: -fx-border-input; -fx-border-radius: 10; -fx-font-size: 14px; -fx-padding: 10 16; -fx-background-radius: 10; -fx-border-color: -fx-border-input; -fx-border-radius: 10;"/>
    </HBox>
    
    <HBox spacing="12" alignment="CENTER_LEFT">
        <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <Label text="بحث:" style="-fx-font-size: 14px;"/>
            <TextField fx:id="searchField" promptText="ابحث بالاسم أو الكود أو الباركود..." prefWidth="300"
                       style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 8;"/>
        </HBox>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="الفئة:" style="-fx-font-size: 14px;"/>
            <ComboBox fx:id="categoryFilter" promptText="الكل" prefWidth="150"
                      style="-fx-background-radius: 8; -fx-border-radius: 8;"/>
        </HBox>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="الحالة:" style="-fx-font-size: 14px;"/>
            <ComboBox fx:id="statusFilter" promptText="الكل" prefWidth="120"
                      style="-fx-background-radius: 8; -fx-border-radius: 8;"/>
        </HBox>
        <Button text="تحديث" onAction="#handleRefresh"
                style="-fx-background-color: -fx-success-text; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8 16; -fx-background-radius: 8;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="عرض المنتج المحدد:" style="-fx-font-size: 13px; -fx-text-fill: -fx-form-sublabel;"/>
        <Button fx:id="batchDetailsButton" text="تفاصيل الدفعات" onAction="#handleBatchDetails" disable="true"
                style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-border-color: -fx-border-input; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 8 14; -fx-background-radius: 8;"/>
        <Button fx:id="movementHistoryButton" text="حركة المخزون" onAction="#handleMovementHistory" disable="true"
                style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-border-color: -fx-border-input; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 8 14; -fx-background-radius: 8;"/>
    </HBox>
    
    <HBox spacing="16">
        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
              style="-fx-background-color: -fx-form-section-bg; -fx-padding: 16; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 10,0,0,4);">
            <Label text="إجمالي المنتجات" style="-fx-font-size: 13px; -fx-text-fill: -fx-form-sublabel;"/>
            <Label fx:id="totalProductsLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: -fx-form-label;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
              style="-fx-background-color: -fx-form-section-bg; -fx-padding: 16; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 10,0,0,4);">
            <Label text="إجمالي المخزون" style="-fx-font-size: 13px; -fx-text-fill: -fx-form-sublabel;"/>
            <Label fx:id="totalStockLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2a8cff;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
              style="-fx-background-color: -fx-form-section-bg; -fx-padding: 16; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 10,0,0,4);">
            <Label text="قيمة المخزون" style="-fx-font-size: 13px; -fx-text-fill: -fx-form-sublabel;"/>
            <Label fx:id="inventoryValueLabel" text="0.00 د.ع" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: -fx-success-text;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
              style="-fx-background-color: -fx-form-section-bg; -fx-padding: 16; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 10,0,0,4);">
            <Label text="منخفض المخزون" style="-fx-font-size: 13px; -fx-text-fill: -fx-form-sublabel;"/>
            <Label fx:id="lowStockLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: -fx-danger-text;"/>
        </VBox>
    </HBox>
    
    <TableView fx:id="productsTable" VBox.vgrow="ALWAYS"
               style="-fx-background-radius: 12; -fx-border-radius: 12;">
        <columns>
            <TableColumn fx:id="codeColumn" text="الكود" prefWidth="100"/>
            <TableColumn fx:id="nameColumn" text="اسم المنتج" prefWidth="180"/>
            <TableColumn fx:id="categoryColumn" text="الفئة" prefWidth="100"/>
            <TableColumn fx:id="barcodeColumn" text="الباركود" prefWidth="110"/>
            <TableColumn fx:id="costPriceColumn" text="التكلفة" prefWidth="90"/>
            <TableColumn fx:id="unitPriceColumn" text="سعر البيع" prefWidth="90"/>
            <TableColumn fx:id="quantityColumn" text="الكمية" prefWidth="150"/>
            <TableColumn fx:id="statusColumn" text="الحالة" prefWidth="80"/>
            <TableColumn fx:id="actionsColumn" text="إجراءات" prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="لا توجد منتجات" style="-fx-font-size: 16px; -fx-text-fill: -fx-text-muted;"/>
        </placeholder>
    </TableView>
    
    <HBox alignment="CENTER_RIGHT" spacing="12">
        <Button fx:id="printReportButton" text="طباعة التقرير" onAction="#handlePrint"
                style="-fx-background-color: -fx-accent-color; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8 16; -fx-background-radius: 8;"/>
        <Label fx:id="statusLabel" text="جاهز" style="-fx-font-size: 13px; -fx-text-fill: -fx-form-sublabel;"/>
    </HBox>
</VBox>
