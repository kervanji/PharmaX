<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pharmax.controller.QuickSaleManagerController"
            stylesheets="@../styles/main.css" prefWidth="920" prefHeight="620"
            styleClass="quick-sale-manager" nodeOrientation="RIGHT_TO_LEFT">
    <top>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="quick-sale-manager-header">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="إدارة لوحة المنتجات السريعة" styleClass="quick-sale-manager-title"/>
                <Label text="نظّم المجموعات والمنتجات والصور التي تظهر في نقطة البيع" styleClass="quick-sale-muted"/>
            </VBox>
            <Button text="إغلاق" onAction="#handleClose" styleClass="quick-sale-secondary-button"/>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.27" nodeOrientation="RIGHT_TO_LEFT">
            <items>
                <VBox spacing="10" styleClass="quick-sale-manager-panel">
                    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                    <Label text="المجموعات" styleClass="quick-sale-section-title"/>
                    <ListView fx:id="groupsList" VBox.vgrow="ALWAYS"/>
                    <HBox spacing="6" alignment="CENTER">
                        <Button text="إضافة" onAction="#handleAddGroup" styleClass="quick-sale-primary-button"/>
                        <Button text="تعديل" onAction="#handleEditGroup" styleClass="quick-sale-secondary-button"/>
                        <Button text="حذف" onAction="#handleDeleteGroup" styleClass="quick-sale-danger-button"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER">
                        <Button text="↑" onAction="#handleGroupUp" styleClass="quick-sale-icon-button"/>
                        <Button text="↓" onAction="#handleGroupDown" styleClass="quick-sale-icon-button"/>
                        <Button text="تفعيل/تعطيل" onAction="#handleToggleGroup" styleClass="quick-sale-secondary-button"/>
                    </HBox>
                </VBox>
                <VBox spacing="12" styleClass="quick-sale-manager-panel">
                    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                    <HBox alignment="CENTER_RIGHT" spacing="8">
                        <Label fx:id="itemsTitle" text="منتجات المجموعة" styleClass="quick-sale-section-title" HBox.hgrow="ALWAYS"/>
                        <Button text="↑" onAction="#handleItemUp" styleClass="quick-sale-icon-button"/>
                        <Button text="↓" onAction="#handleItemDown" styleClass="quick-sale-icon-button"/>
                        <Button text="حذف المنتج" onAction="#handleDeleteItem" styleClass="quick-sale-danger-button"/>
                    </HBox>
                    <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="productColumn" text="المنتج" prefWidth="210"/>
                            <TableColumn fx:id="unitColumn" text="وحدة البيع" prefWidth="120"/>
                            <TableColumn fx:id="imageColumn" text="صورة" prefWidth="80"/>
                            <TableColumn fx:id="orderColumn" text="الترتيب" prefWidth="70"/>
                        </columns>
                        <placeholder><Label text="لم تتم إضافة منتجات إلى هذه المجموعة"/></placeholder>
                    </TableView>
                    <GridPane hgap="10" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="18"/>
                            <ColumnConstraints percentWidth="32"/>
                            <ColumnConstraints percentWidth="18"/>
                            <ColumnConstraints percentWidth="32"/>
                        </columnConstraints>
                        <Label text="المنتج" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="productCombo" promptText="اختر المنتج" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="الوحدة" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="unitCombo" promptText="الوحدة الافتراضية" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                        <Label text="لون البطاقة" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="accentCombo" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="الصورة" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <HBox spacing="6" alignment="CENTER_RIGHT" GridPane.rowIndex="1" GridPane.columnIndex="3">
                            <ImageView fx:id="imagePreview" fitWidth="54" fitHeight="54" preserveRatio="true"/>
                            <VBox spacing="4">
                                <Button text="اختيار" onAction="#handleChooseImage" styleClass="quick-sale-secondary-button"/>
                                <Button text="إزالة" onAction="#handleRemoveImage" styleClass="quick-sale-secondary-button"/>
                            </VBox>
                        </HBox>
                    </GridPane>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Button fx:id="saveItemButton" text="إضافة إلى المجموعة" onAction="#handleSaveItem" styleClass="quick-sale-primary-button"/>
                        <Button text="مسح الاختيار" onAction="#handleClearItemForm" styleClass="quick-sale-secondary-button"/>
                    </HBox>
                    <Label fx:id="statusLabel" text="" styleClass="quick-sale-muted" wrapText="true"/>
                </VBox>
            </items>
        </SplitPane>
    </center>
</BorderPane>
