<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pharmax.controller.CustomerController"
            fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: transparent; -fx-background: transparent;">
    
    <VBox stylesheets="@../styles/main.css"
          spacing="20"
          style="-fx-background-color: -fx-bg-gradient; -fx-padding: 24; -fx-font-family: 'Geeza Pro', 'SF Arabic', 'Arial', 'Tahoma';">
    
    <!-- Header -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label fx:id="formTitleLabel" text="إضافة عميل جديد" 
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: -fx-text-main;"/>
    </HBox>
    
    <!-- Form Grid -->
    <GridPane hgap="16" vgap="14" style="-fx-background-color: -fx-form-section-bg; -fx-padding: 24; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 14, 0, 0, 6);">
        
        <!-- Customer Code -->
        <Label text="كود العميل:" GridPane.columnIndex="1" GridPane.rowIndex="0"
               style="-fx-font-size: 14px; -fx-text-fill: -fx-form-label; -fx-font-weight: bold;"/>
        <TextField fx:id="customerCodeField" GridPane.columnIndex="0" GridPane.rowIndex="0"
                   promptText="سيتم توليده تلقائياً" editable="false"
                   style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-prompt-text-fill: -fx-text-hint; -fx-padding: 10; -fx-background-radius: 8; -fx-pref-width: 250;"/>
        
        <!-- Customer Name -->
        <Label text="اسم العميل: *" GridPane.columnIndex="1" GridPane.rowIndex="1"
               style="-fx-font-size: 14px; -fx-text-fill: -fx-form-label; -fx-font-weight: bold;"/>
        <TextField fx:id="customerNameField" GridPane.columnIndex="0" GridPane.rowIndex="1"
                   promptText="أدخل اسم العميل"
                   style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-prompt-text-fill: -fx-text-hint; -fx-padding: 10; -fx-background-radius: 8; -fx-pref-width: 250;"/>
        
        <!-- Phone Number -->
        <Label text="رقم الهاتف (07...): *" GridPane.columnIndex="1" GridPane.rowIndex="2"
               style="-fx-font-size: 14px; -fx-text-fill: -fx-form-label; -fx-font-weight: bold;"/>
        <TextField fx:id="phoneNumberField" GridPane.columnIndex="0" GridPane.rowIndex="2"
                   promptText="07xxxxxxxx"
                   style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-prompt-text-fill: -fx-text-hint; -fx-padding: 10; -fx-background-radius: 8; -fx-pref-width: 250;"/>
        
        <!-- Address -->
        <Label text="العنوان:" GridPane.columnIndex="1" GridPane.rowIndex="3"
               style="-fx-font-size: 14px; -fx-text-fill: -fx-form-label; -fx-font-weight: bold;"/>
        <TextField fx:id="addressField" GridPane.columnIndex="0" GridPane.rowIndex="3"
                   promptText="عنوان العميل"
                   style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-prompt-text-fill: -fx-text-hint; -fx-padding: 10; -fx-background-radius: 8; -fx-pref-width: 250;"/>
        
        <!-- Project Location -->
        <Label text="مواقع المشاريع: *" GridPane.columnIndex="1" GridPane.rowIndex="4"
               style="-fx-font-size: 14px; -fx-text-fill: -fx-form-label; -fx-font-weight: bold;"/>
        <TextArea fx:id="projectLocationsArea" GridPane.columnIndex="0" GridPane.rowIndex="4"
                  promptText="اكتب كل موقع في سطر منفصل"
                  prefRowCount="3"
                  style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-prompt-text-fill: -fx-text-hint; -fx-padding: 10; -fx-background-radius: 8; -fx-pref-width: 250;"/>
        
        <columnConstraints>
            <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS"/>
            <javafx.scene.layout.ColumnConstraints hgrow="NEVER" minWidth="120"/>
        </columnConstraints>
    </GridPane>
    
    <!-- Action Buttons -->
    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 16 0 0 0; -fx-border-color: -fx-border-main transparent transparent transparent; -fx-border-width: 1 0 0 0;">
        <Button fx:id="saveButton" text="حفظ" onAction="#handleSave" prefWidth="120"
                style="-fx-background-color: linear-gradient(to right, -fx-accent-light, -fx-accent-color); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 24; -fx-background-radius: 10;"/>
        <Button text="إلغاء" onAction="#handleCancel" prefWidth="100"
                style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-border-color: -fx-border-input; -fx-border-radius: 10; -fx-font-size: 14px; -fx-padding: 12 24; -fx-background-radius: 10;"/>
    </HBox>
</VBox>
</ScrollPane>
