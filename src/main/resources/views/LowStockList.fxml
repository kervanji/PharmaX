<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmax.controller.LowStockController"
      stylesheets="@../styles/main.css"
      spacing="16"
      style="-fx-background-color: -fx-bg-gradient; -fx-padding: 24;">
    
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4">
            <Label text="تنبيهات المخزون المنخفض" 
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -fx-form-label;"/>
            <Label text="المنتجات التي وصلت أو تجاوزت الحد الأدنى للمخزون"
                   style="-fx-font-size: 14px; -fx-text-fill: -fx-form-sublabel;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="تحديث" onAction="#handleRefresh"
                style="-fx-background-color: -fx-success-text; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 10;"/>
        <Button text="تصدير التقرير" onAction="#handleExport"
                style="-fx-background-color: -fx-bg-surface; -fx-text-fill: -fx-form-label; -fx-border-color: -fx-border-input; -fx-border-radius: 10; -fx-font-size: 14px; -fx-padding: 10 16; -fx-background-radius: 10; -fx-border-color: -fx-border-input; -fx-border-radius: 10;"/>
    </HBox>
    
    <HBox spacing="16">
        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
              style="-fx-background-color: -fx-danger-bg; -fx-padding: 16; -fx-background-radius: 12; -fx-border-color: -fx-danger; -fx-border-radius: 12;">
            <Label text="منتجات منخفضة المخزون" style="-fx-font-size: 13px; -fx-text-fill: -fx-danger-text;"/>
            <Label fx:id="lowStockCountLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: -fx-danger-text;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
              style="-fx-background-color: -fx-badge-warning-bg; -fx-padding: 16; -fx-background-radius: 12; -fx-border-color: -fx-warning-dark; -fx-border-radius: 12;">
            <Label text="منتجات نفدت" style="-fx-font-size: 13px; -fx-text-fill: -fx-warning-dark;"/>
            <Label fx:id="outOfStockLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: -fx-warning-dark;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
              style="-fx-background-color: -fx-success-bg; -fx-padding: 16; -fx-background-radius: 12; -fx-border-color: -fx-success-dark; -fx-border-radius: 12;">
            <Label text="تكلفة إعادة التخزين المقدرة" style="-fx-font-size: 13px; -fx-text-fill: -fx-success-dark;"/>
            <Label fx:id="restockCostLabel" text="0.00 د.ع" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: -fx-success-dark;"/>
        </VBox>
    </HBox>
    
    <TableView fx:id="lowStockTable" VBox.vgrow="ALWAYS"
               style="-fx-background-radius: 12; -fx-border-radius: 12;">
        <columns>
            <TableColumn fx:id="codeColumn" text="الكود" prefWidth="100"/>
            <TableColumn fx:id="nameColumn" text="اسم المنتج" prefWidth="200"/>
            <TableColumn fx:id="categoryColumn" text="الفئة" prefWidth="100"/>
            <TableColumn fx:id="currentStockColumn" text="المخزون الحالي" prefWidth="110"/>
            <TableColumn fx:id="minimumStockColumn" text="الحد الأدنى" prefWidth="100"/>
            <TableColumn fx:id="neededColumn" text="الكمية المطلوبة" prefWidth="110"/>
            <TableColumn fx:id="costColumn" text="تكلفة التخزين" prefWidth="110"/>
            <TableColumn fx:id="actionsColumn" text="إجراءات" prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="لا توجد منتجات منخفضة المخزون ✓" style="-fx-font-size: 16px; -fx-text-fill: -fx-success-text;"/>
        </placeholder>
    </TableView>
    
    <HBox alignment="CENTER_RIGHT" spacing="12">
        <Label fx:id="lastUpdateLabel" text="آخر تحديث: --" style="-fx-font-size: 13px; -fx-text-fill: -fx-form-sublabel;"/>
    </HBox>
</VBox>
